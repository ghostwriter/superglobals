{
    "name": "ghostwriter/wip",
    "description": "Here be dragons",
    "license": "BSD-3-Clause",
    "type": "library",
    "keywords": [
        "ghostwriter",
        "wip"
    ],
    "authors": [
        {
            "name": "Nathanael Esayeas",
            "email": "nathanael.esayeas@protonmail.com",
            "homepage": "https://github.com/ghostwriter",
            "role": "Developer"
        }
    ],
    "homepage": "https://github.com/ghostwriter/wip",
    "support": {
        "issues": "https://github.com/ghostwriter/wip/issues",
        "source": "https://github.com/ghostwriter/wip",
        "rss": "https://github.com/ghostwriter/wip/releases.atom",
        "security": "https://github.com/ghostwriter/wip/security/advisories/new"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/ghostwriter"
        },
        {
            "type": "paypal",
            "url": "https://paypal.me/codepoet"
        }
    ],
    "_comment": [
        "#BlackLivesMatter",
        "#FreePalestine",
        "#StandWithIran",
        "#StandWithUkraine",
        "#StopGenocide"
    ],
    "require": {
        "php": "~8.4.0 || ~8.5.0 || ~8.6.0",
        "ext-mbstring": "*",
        "ghostwriter/case-converter": "^2.2.2",
        "ghostwriter/clock": "^3.0.2",
        "ghostwriter/collection": "^2.1.0",
        "ghostwriter/config": "^2.1.3",
        "ghostwriter/container": "^7.0.2",
        "ghostwriter/event-dispatcher": "^6.1.3",
        "ghostwriter/filesystem": "^0.2.0",
        "ghostwriter/json": "^3.0.2",
        "ghostwriter/option": "^2.0.0",
        "ghostwriter/result": "^2.0.0",
        "ghostwriter/shell": "^0.1.5",
        "ghostwriter/uuid": "^1.0.3"
    },
    "require-dev": {
        "ext-xdebug": "*",
        "boundwize/structarmed": "^0.10.0",
        "ghostwriter/coding-standard": "dev-main",
        "ghostwriter/phpunit-assertions": "^0.1.0",
        "ghostwriter/testify": "^0.1.2",
        "mockery/mockery": "^1.6.12",
        "phpunit/phpunit": "^13.1.12",
        "symfony/var-dumper": "^8.1.0"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Ghostwriter\\Wip\\": "src"
        },
        "files": [
            "src/constants.php",
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        },
        "files": [
            "tests/bootstrap.php"
        ],
        "exclude-from-classmap": [
            "/tests/"
        ]
    },
    "bin": [
        "bin/console",
        "bin/console.php"
    ],
    "config": {
        "allow-plugins": {
            "ghostwriter/coding-standard": true
        },
        "bump-after-update": false,
        "classmap-authoritative": false,
        "discard-changes": true,
        "optimize-autoloader": true,
        "platform": {
            "php": "8.4.999"
        },
        "platform-check": true,
        "policy": {
            "advisories": {
                "block": true,
                "audit": "fail"
            },
            "malware": {
                "block": true,
                "block-scope": "all",
                "audit": "fail"
            },
            "abandoned": {
                "block": true,
                "audit": "fail"
            }
        },
        "preferred-install": {
            "*": "dist"
        },
        "prepend-autoloader": true,
        "process-timeout": 5000,
        "sort-packages": true,
        "strict-psr-autoloader": true,
        "use-parent-dir": false
    },
    "extra": {
        "thanks": {
            "name": "ghostwriter/wip",
            "url": "https://github.com/ghostwriter/wip"
        }
    },
    "scripts": {
        "cache:clear": "rm -rf ./.cache/*",
        "check": [
            "@cache:clear",
            "@composer validate",
            "@test"
        ],
        "infection": [
            "@xdebug",
            "vendor/ghostwriter/coding-standard/tools/phar/infection --min-covered-msi=0 --min-msi=0 --show-mutations --threads=max"
        ],
        "phpunit": [
            "@xdebug",
            "vendor/bin/phpunit --do-not-cache-result --colors=always"
        ],
        "test": [
            "@phpunit",
            "@infection"
        ],
        "xdebug": "@putenv XDEBUG_MODE=coverage"
    }
}
